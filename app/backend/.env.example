# ============================================================
# BACKEND — Variables de entorno
# Renombrar este archivo a .env y completar los valores reales
# NUNCA subir el .env real a Git (.gitignore lo excluye)
# ============================================================

# Puerto en el que escucha Express (dentro de la subred privada)
PORT=3001

# ── Base de datos (RDS PostgreSQL) ──────────────────────────
# Endpoint del RDS: se obtiene en AWS Console → RDS → Databases → <tu-instancia> → Endpoint
DB_HOST=tu-instancia.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=salon_db
DB_USER=salon_admin
DB_PASSWORD=TuContraseñaSegura123!

# ── CORS ────────────────────────────────────────────────────
# IP pública o DNS del ALB / EC2 frontend (SOLO esa IP puede llamar al backend)
# Ejemplo: http://ec2-xx-xx-xx-xx.compute-1.amazonaws.com
# En producción usa HTTPS: https://tudominio.com
CORS_ORIGIN=http://IP_O_DNS_DEL_FRONTEND

# ── Entorno ─────────────────────────────────────────────────
NODE_ENV=production
