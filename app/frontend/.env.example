# ============================================================
# FRONTEND — Variables de entorno Vite
# Las variables VITE_* se exponen al bundle del navegador
# Renombrar a .env y completar con la IP/DNS del backend
# ============================================================

# IP privada del EC2 backend (dentro de la VPC)
# El frontend (en subred pública) se comunica con el backend (subred privada)
# a través del enrutamiento interno de la VPC — NO pasa por Internet
VITE_API_URL=http://10.0.2.XX:3001/api

# En producción con ALB interno, usar el DNS del ALB interno:
# VITE_API_URL=http://internal-salon-alb-backend.us-east-1.elb.amazonaws.com/api
